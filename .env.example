# =============================================================================
# Railway / production (set in Railway Variables; copy locally only for prod-like tests)
# =============================================================================
# Required:
#   DJANGO_SETTINGS_MODULE=config.settings.prod
#   DJANGO_SECRET_KEY=<strong random string — never commit real values>
#   DATABASE_URL=postgresql://...
#   ALLOWED_HOSTS=your-api.up.railway.app,localhost
#   REDIS_URL=redis://...  or rediss://...  (web + worker + recommended for cache)
#   CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
#   CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app
#
# Strongly recommended:
#   DB_CONN_MAX_AGE=60   (prod defaults to 60 if unset when using config.settings.prod)
#
# Optional (override Celery URLs; otherwise broker/result use REDIS_URL):
#   CELERY_BROKER_URL=redis://.../0
#   CELERY_RESULT_BACKEND=redis://.../1
#
# Optional S3 / R2 (persistent media — Railway disk is ephemeral):
#   USE_S3=1
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   AWS_STORAGE_BUCKET_NAME=...
#   AWS_S3_REGION_NAME=...          # optional for R2
#   AWS_S3_ENDPOINT_URL=...         # R2 / MinIO endpoint
# =============================================================================

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
# DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL only (no SQLite fallback)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/postgres

# Option B: if DATABASE_URL is unset
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# Persistent DB connections (seconds). Prod uses 60 by default if omitted; set 0 to disable.
# DB_CONN_MAX_AGE=60

# Redis — set on Railway for cache + Celery (same variable reference in config/settings/base.py)
# REDIS_URL=redis://default:password@host:6379
# CELERY_BROKER_URL=redis://default:password@host:6379/0
# CELERY_RESULT_BACKEND=redis://default:password@host:6379/1

# CORS & CSRF (comma-separated; use https origins in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# TLS / proxy (Railway terminates TLS)
# USE_TLS_PROXY_HEADERS=1
# SECURE_SSL_REDIRECT=1
# SESSION_COOKIE_SECURE=1
# CSRF_COOKIE_SECURE=1
# After HTTPS is verified end-to-end: SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=0
# SECURE_HSTS_PRELOAD=0

# Gunicorn (Linux/Railway). On Windows use: python manage.py runserver
# PORT=8000
# WEB_CONCURRENCY=4
# GUNICORN_THREADS=8
# GUNICORN_TIMEOUT=120

# Celery worker tuning
# CELERY_WORKER_CONCURRENCY=4
# CELERY_WORKER_PREFETCH_MULTIPLIER=4

# Optional S3-compatible media
# USE_S3=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_ADDRESSING_STYLE=auto
# AWS_DEFAULT_ACL=
# AWS_QUERYSTRING_AUTH=1

# Credential encryption (bulk import registry)
# CREDENTIALS_ENCRYPTION_KEY=

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# Media / uploads tuning (see config/settings/base.py)
# IMAGE_UPLOAD_MAX_WIDTH=1200
# CANVAS_MEDIA_RETENTION_DAYS=90

# Seed data (development only)
SEED_TEACHER_EMAIL=teacher@bekrinschool.az
SEED_TEACHER_PASSWORD=teacher123
SEED_STUDENT_PASSWORD=student123
SEED_PARENT_PASSWORD=parent123
